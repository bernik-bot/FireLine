# Copy to .env and fill in. NEVER commit .env.
# Strong Postgres password
DB_PASSWORD=change-me-to-a-long-random-string

# Control-plane Ed25519 signing key (base64). Generate with:
#   make signing-key      (or see README)
# In real production this belongs in Vault/KMS, not a .env file.
BLACKBIRCH_SIGNING_KEY=

# Optional: Slack/Teams incoming webhook for alert fan-out
BLACKBIRCH_WEBHOOK_URL=
